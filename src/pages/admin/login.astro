---
export const prerender = false;

// /admin/login, Login-Seite für Kristina
// Supabase Auth: signInWithPassword
// Bei Erfolg: Session-Cookie setzen, redirect nach /admin

// Falls schon eingeloggt → redirect
const accessToken = Astro.cookies.get("sb-access-token")?.value;
if (accessToken) {
  return Astro.redirect("/admin");
}
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login · Jetski Lefkada Rentals</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: "Instrument Sans", ui-sans-serif, system-ui, sans-serif;
        background: linear-gradient(135deg, #071d30, #0a2540);
        color: #fdfbf4;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }
      .card {
        background: rgba(253, 251, 244, 0.04);
        border: 1px solid rgba(253, 251, 244, 0.15);
        border-radius: 16px;
        padding: 3rem;
        max-width: 420px;
        width: 100%;
      }
      h1 {
        font-family: "Fraunces Variable", Georgia, serif;
        font-size: 2.25rem;
        font-weight: 400;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }
      h1 em { color: #ffc233; font-style: italic; }
      .subtitle {
        color: rgba(253, 251, 244, 0.65);
        font-size: 0.9rem;
        margin-bottom: 2rem;
      }
      label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(253, 251, 244, 0.65);
        margin-bottom: 0.5rem;
      }
      input {
        width: 100%;
        padding: 0.75rem 1rem;
        background: rgba(253, 251, 244, 0.05);
        border: 1px solid rgba(253, 251, 244, 0.15);
        border-radius: 8px;
        color: #fdfbf4;
        font-size: 1rem;
        margin-bottom: 1.25rem;
      }
      input:focus {
        outline: none;
        border-color: #ffc233;
      }
      button {
        width: 100%;
        padding: 0.875rem;
        background: #ffc233;
        color: #071d30;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: opacity 0.15s;
      }
      button:hover { opacity: 0.9; }
      button:disabled { opacity: 0.5; cursor: not-allowed; }
      .error {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.4);
        border-radius: 8px;
        color: #fca5a5;
        font-size: 0.85rem;
        display: none;
      }
      .error.show { display: block; }
      .footer-note {
        margin-top: 2rem;
        text-align: center;
        font-size: 0.75rem;
        color: rgba(253, 251, 244, 0.4);
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Admin <em>Login</em></h1>
      <p class="subtitle">Jetski Lefkada Rentals · Kristina only</p>

      <form id="login-form">
        <label for="email">Geschäftsmail</label>
        <input id="email" name="email" type="email" required autocomplete="email" placeholder="info@jetski-lefkada-rentals.com" />

        <label for="password">Passwort</label>
        <input id="password" name="password" type="password" required autocomplete="current-password" />

        <button type="submit" id="submit-btn">Einloggen</button>

        <div class="error" id="error-msg"></div>
      </form>

      <div class="footer-note">
        Login nur mit <strong style="color: rgba(253, 251, 244, 0.8);">info@jetski-lefkada-rentals.com</strong><br />
        Bei Problemen: David via WhatsApp.
      </div>
    </div>

    <script>
      const form = document.getElementById("login-form") as HTMLFormElement;
      const errorEl = document.getElementById("error-msg") as HTMLDivElement;
      const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorEl.classList.remove("show");
        submitBtn.disabled = true;
        submitBtn.textContent = "Anmelden...";

        const formData = new FormData(form);
        const email = formData.get("email") as string;
        const password = formData.get("password") as string;

        try {
          const res = await fetch("/api/admin/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password }),
          });

          const data = await res.json();

          if (!res.ok) {
            errorEl.textContent = data.error || "Login fehlgeschlagen";
            errorEl.classList.add("show");
            return;
          }

          window.location.href = "/admin";
        } catch (err) {
          errorEl.textContent = "Netzwerkfehler. Bitte erneut versuchen.";
          errorEl.classList.add("show");
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = "Einloggen";
        }
      });
    </script>
  </body>
</html>
