---
export const prerender = false;

import AdminShell from "../../components/admin/AdminShell.astro";
import { jetskiUnits, jetskis } from "../../data/jetskis";

const accessToken = Astro.cookies.get("sb-access-token")?.value;
if (!accessToken) {
  return Astro.redirect("/admin/login");
}

// TODO: Buchungen der aktuellen Woche aus Supabase laden
// Gruppiert nach jetski_unit_id
const bookingsThisWeek: any[] = [];

// Aktuelle Woche berechnen (Montag–Sonntag)
const today = new Date();
const dayOfWeek = today.getDay() === 0 ? 6 : today.getDay() - 1; // Mo=0..So=6
const monday = new Date(today);
monday.setDate(today.getDate() - dayOfWeek);
const weekDays = Array.from({ length: 7 }, (_, i) => {
  const d = new Date(monday);
  d.setDate(monday.getDate() + i);
  return {
    date: d.toISOString().slice(0, 10),
    label: d.toLocaleDateString("de-DE", { weekday: "short", day: "2-digit", month: "2-digit" }),
    isToday: d.toDateString() === today.toDateString(),
  };
});

// Token aus Environment. Kein Fallback-String mehr (Sec #5, 2026-04-20):
// wenn ENV fehlt, ist tokenIsSet false → Feed-URL wird in UI nicht gezeigt,
// der /api/calendar.ics-Endpoint verweigert ohnehin bei ungültigem Token.
const token = import.meta.env.CALENDAR_FEED_TOKEN ?? "";
const siteUrl = Astro.site?.toString() ?? "https://jetski-lefkada-rentals.com";
const tokenIsSet = token.length >= 20;
const feedUrl = tokenIsSet
  ? `${siteUrl.replace(/\/$/, "")}/api/calendar.ics?token=${token}`
  : "";
---

<AdminShell title="Kalender" activePath="calendar">
  <div style="margin-bottom: 2rem;">
    <h1 style="font-family: 'Fraunces Variable', Georgia, serif; font-size: 2.5rem; font-weight: 400; letter-spacing: -0.02em;">
      Flotten-Kalender
    </h1>
    <p style="color: rgba(253, 251, 244, 0.65); margin-top: 0.5rem;">
      Wer hat wann welchen Jetski? Alle 4 Einheiten auf einen Blick.
    </p>
  </div>

  <!-- Fleet-Kalender (Wochenansicht pro Jetski) -->
  <section style="margin-bottom: 4rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
      <h3 style="font-family: 'Fraunces Variable', Georgia, serif; font-size: 1.25rem; font-weight: 400; margin: 0;">
        Diese Woche ({weekDays[0].date} – {weekDays[6].date})
      </h3>
      <div style="display: flex; gap: 0.5rem;">
        <button class="btn-secondary" disabled>&larr; Vorherige</button>
        <button class="btn-secondary">Heute</button>
        <button class="btn-secondary" disabled>Nächste &rarr;</button>
      </div>
    </div>

    <div class="fleet-grid">
      <!-- Header-Zeile: Wochentage -->
      <div class="grid-cell header-cell">Jetski</div>
      {weekDays.map((d) => (
        <div class={`grid-cell header-cell ${d.isToday ? "is-today" : ""}`}>
          {d.label}
          {d.isToday && <span class="today-dot"></span>}
        </div>
      ))}

      <!-- Pro Unit eine Zeile -->
      {jetskiUnits.map((unit) => (
        <>
          <div class="grid-cell unit-cell">
            <div class="unit-label">{unit.label}</div>
            <div class="unit-sub">{jetskis.find((j) => j.id === unit.modelId)?.model ?? unit.modelId}</div>
            <div class={`unit-status status-${unit.status}`}>{unit.status}</div>
          </div>
          {weekDays.map((d) => {
            const daysBookings = bookingsThisWeek.filter(
              (b) => b.jetski_unit_id === unit.id && b.booking_date === d.date
            );
            return (
              <div class={`grid-cell slot-cell ${d.isToday ? "is-today" : ""}`}>
                {daysBookings.length === 0 ? (
                  <span class="empty-slot">—</span>
                ) : (
                  daysBookings.map((b: any) => (
                    <a href={`/admin/bookings/${b.id}`} class="booking-pill">
                      <div class="booking-time">{b.start_time} · {b.duration_minutes}min</div>
                      <div class="booking-name">{b.customer_name}</div>
                    </a>
                  ))
                )}
              </div>
            );
          })}
        </>
      ))}
    </div>

    {bookingsThisWeek.length === 0 && (
      <div class="empty-banner">
        Noch keine Buchungen diese Woche — sobald Supabase angebunden ist und Du Buchungen eintragst, erscheinen sie hier automatisch in der richtigen Zeile + Spalte.
      </div>
    )}
  </section>

  <!-- Outlook-Sync-Setup darunter -->
  <div style="margin: 3rem 0 2rem;">
    <h2 style="font-family: 'Fraunces Variable', Georgia, serif; font-size: 1.75rem; font-weight: 400; letter-spacing: -0.02em;">
      Outlook-Kalender-Sync (optional)
    </h2>
    <p style="color: rgba(253, 251, 244, 0.65); margin-top: 0.5rem;">
      Abonniere Deine CRM-Buchungen zusätzlich in Outlook auf dem Laptop.
    </p>
  </div>

  {!tokenIsSet && (
    <div class="warning-box">
      <h3>⚠ Kalender-Token noch nicht eingerichtet</h3>
      <p>
        Lege in <code>.env.local</code> folgende Zeile an:<br />
        <code class="code-block">CALENDAR_FEED_TOKEN=ein-langes-geheimes-passwort-hier</code>
      </p>
      <p style="margin-top: 0.75rem;">Das Token muss mindestens 32 Zeichen lang sein. Dann Server neu starten.</p>
    </div>
  )}

  <!-- Feed-URL -->
  <div class="feed-box">
    <label>Dein privater iCal-Feed:</label>
    <div class="url-row">
      <input type="text" value={feedUrl} readonly id="feed-url" />
      <button id="copy-btn">Kopieren</button>
    </div>
    <p class="note">
      ⚠ Behalte diese URL geheim. Sie gibt Lesezugriff auf alle Deine Buchungen.
    </p>
  </div>

  <!-- Setup-Anleitung -->
  <h3 class="section-title">Outlook einrichten (Windows-Laptop)</h3>
  <ol class="setup-list">
    <li>
      <strong>Outlook öffnen</strong>
      <p>Desktop-App auf Deinem Laptop (nicht die Web-Version).</p>
    </li>
    <li>
      <strong>Datei → Kontoeinstellungen → Kontoeinstellungen</strong>
      <p>Oben links in Outlook → Dropdown mit Kontoverwaltung.</p>
    </li>
    <li>
      <strong>Tab „Internetkalender" → „Neu"</strong>
      <p>Auf den Tab wechseln und auf den Neu-Button klicken.</p>
    </li>
    <li>
      <strong>Die URL oben kopieren und einfügen</strong>
      <p>Das Feld heißt „Ort des Internetkalenders".</p>
    </li>
    <li>
      <strong>Bestätigen + Name vergeben</strong>
      <p>
        Name: <code>Jetski Lefkada Rentals · Buchungen</code><br />
        Beschreibung: <code>CRM-Buchungen (schreibgeschützt)</code>
      </p>
    </li>
    <li>
      <strong>Fertig</strong>
      <p>
        Outlook zeigt Deine Buchungen jetzt automatisch an. Aktualisierung erfolgt alle 1–2 Stunden.
      </p>
    </li>
  </ol>

  <!-- Wichtige Hinweise -->
  <h3 class="section-title">Wichtig</h3>
  <ul class="info-list">
    <li>📖 <strong>Schreibgeschützt:</strong> Du siehst in Outlook, kannst aber nicht direkt editieren. Änderungen im CRM machen → Outlook updatet sich automatisch.</li>
    <li>🔄 <strong>Sync-Rhythmus:</strong> Outlook fragt die URL alle 1–2 Stunden ab. Für sofortige Aktualisierung: Rechtsklick auf Kalender → „Senden/Empfangen".</li>
    <li>🔒 <strong>Sicherheit:</strong> URL niemals weitergeben. Bei Verdacht auf Missbrauch: neues Token generieren.</li>
    <li>📱 <strong>Handy:</strong> Funktioniert auch mit iOS/Android-Kalendern (als „Internetkalender" hinzufügen).</li>
  </ul>
</AdminShell>

<style>
  /* Fleet-Kalender-Grid */
  .fleet-grid {
    display: grid;
    grid-template-columns: 200px repeat(7, 1fr);
    gap: 2px;
    background: rgba(253, 251, 244, 0.08);
    border: 1px solid rgba(253, 251, 244, 0.1);
    border-radius: 12px;
    overflow: hidden;
  }
  .grid-cell {
    background: rgba(7, 29, 48, 0.92);
    padding: 0.75rem 0.6rem;
    min-height: 60px;
    font-size: 0.82rem;
  }
  .header-cell {
    background: rgba(0, 0, 0, 0.35);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(253, 251, 244, 0.6);
    text-align: center;
    font-weight: 500;
    position: relative;
  }
  .header-cell.is-today {
    background: rgba(255, 194, 51, 0.12);
    color: #ffc233;
  }
  .today-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #ffc233;
    margin-left: 0.3rem;
  }
  .unit-cell {
    background: rgba(0, 0, 0, 0.25);
  }
  .unit-label {
    font-family: "Fraunces Variable", Georgia, serif;
    font-size: 1rem;
    color: #fdfbf4;
  }
  .unit-sub {
    font-size: 0.7rem;
    color: rgba(253, 251, 244, 0.5);
    margin-top: 0.15rem;
  }
  .unit-status {
    display: inline-block;
    margin-top: 0.4rem;
    padding: 0.1rem 0.5rem;
    font-size: 0.65rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .status-active { background: rgba(34, 197, 94, 0.15); color: #86efac; }
  .status-maintenance { background: rgba(255, 194, 51, 0.15); color: #ffc233; }
  .status-retired { background: rgba(239, 68, 68, 0.15); color: #fca5a5; }

  .slot-cell {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .slot-cell.is-today { background: rgba(255, 194, 51, 0.04); }
  .empty-slot { color: rgba(253, 251, 244, 0.2); text-align: center; margin: auto; }

  .booking-pill {
    display: block;
    padding: 0.4rem 0.5rem;
    background: rgba(255, 194, 51, 0.15);
    border-left: 2px solid #ffc233;
    border-radius: 4px;
    text-decoration: none;
    color: #fdfbf4;
    font-size: 0.7rem;
    line-height: 1.3;
  }
  .booking-pill:hover { background: rgba(255, 194, 51, 0.25); }
  .booking-time { font-weight: 600; color: #ffc233; }
  .booking-name { color: rgba(253, 251, 244, 0.85); margin-top: 0.1rem; }

  .empty-banner {
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 194, 51, 0.05);
    border: 1px dashed rgba(255, 194, 51, 0.3);
    border-radius: 8px;
    color: rgba(253, 251, 244, 0.7);
    font-size: 0.88rem;
  }

  .btn-secondary {
    padding: 0.55rem 1rem;
    background: transparent;
    color: #fdfbf4;
    border: 1px solid rgba(253, 251, 244, 0.25);
    border-radius: 8px;
    font-size: 0.85rem;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-secondary:hover:not(:disabled) { background: rgba(253, 251, 244, 0.05); }
  .btn-secondary:disabled { opacity: 0.35; cursor: not-allowed; }

  /* Responsive */
  @media (max-width: 900px) {
    .fleet-grid { grid-template-columns: 120px repeat(7, minmax(80px, 1fr)); overflow-x: auto; }
  }

  .warning-box {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }
  .warning-box h3 {
    font-family: "Fraunces Variable", Georgia, serif;
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
    color: #fca5a5;
  }
  .warning-box p {
    color: rgba(253, 251, 244, 0.8);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .code-block {
    display: inline-block;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    background: rgba(0, 0, 0, 0.3);
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    color: #ffc233;
    margin-top: 0.4rem;
  }

  .feed-box {
    background: rgba(253, 251, 244, 0.04);
    border: 1px solid rgba(253, 251, 244, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
  }
  .feed-box label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(253, 251, 244, 0.5);
    margin-bottom: 0.75rem;
  }
  .url-row { display: flex; gap: 0.5rem; }
  .url-row input {
    flex: 1;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(253, 251, 244, 0.1);
    border-radius: 8px;
    color: #ffc233;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
  }
  #copy-btn {
    padding: 0.75rem 1.25rem;
    background: #ffc233;
    color: #071d30;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
  }
  .note {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: rgba(253, 251, 244, 0.5);
  }

  .section-title {
    font-family: "Fraunces Variable", Georgia, serif;
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
  }

  .setup-list {
    list-style: none;
    counter-reset: step;
    padding: 0;
  }
  .setup-list li {
    counter-increment: step;
    padding: 1.25rem 0 1.25rem 3rem;
    position: relative;
    border-bottom: 1px solid rgba(253, 251, 244, 0.05);
  }
  .setup-list li:last-child { border-bottom: none; }
  .setup-list li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 1.25rem;
    width: 2rem;
    height: 2rem;
    background: rgba(255, 194, 51, 0.15);
    color: #ffc233;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .setup-list strong {
    display: block;
    color: #fdfbf4;
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }
  .setup-list p {
    color: rgba(253, 251, 244, 0.65);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }
  .setup-list code {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    background: rgba(0, 0, 0, 0.3);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    color: #ffc233;
  }

  .info-list {
    list-style: none;
    padding: 0;
  }
  .info-list li {
    padding: 0.75rem 0;
    color: rgba(253, 251, 244, 0.85);
    font-size: 0.9rem;
    line-height: 1.6;
  }
</style>

<script>
  const copyBtn = document.getElementById("copy-btn") as HTMLButtonElement;
  const urlInput = document.getElementById("feed-url") as HTMLInputElement;

  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(urlInput.value);
      copyBtn.textContent = "✓ Kopiert";
      setTimeout(() => { copyBtn.textContent = "Kopieren"; }, 1800);
    } catch {
      urlInput.select();
      document.execCommand("copy");
      copyBtn.textContent = "✓ Kopiert";
      setTimeout(() => { copyBtn.textContent = "Kopieren"; }, 1800);
    }
  });
</script>
