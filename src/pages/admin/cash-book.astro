---
export const prerender = false;

import AdminShell from "../../components/admin/AdminShell.astro";

const accessToken = Astro.cookies.get("sb-access-token")?.value;
if (!accessToken) {
  return Astro.redirect("/admin/login");
}

// TODO: Supabase-Aggregation sobald live
// const { data: payments } = await supabase.from('payments').select('*, bookings(customer_name)').order('payment_date', { descending: true });
// const { data: expenses } = await supabase.from('expenses').select('*').order('expense_date', { descending: true });

const payments: any[] = [];
const expenses: any[] = [];

const totalIncome = payments.reduce((sum, p) => sum + Number(p.amount), 0);
const totalExpenses = expenses.reduce((sum, e) => sum + Number(e.amount), 0);
const balance = totalIncome - totalExpenses;

const currentMonth = new Date().toLocaleDateString("de-DE", { month: "long", year: "numeric" });
---

<AdminShell title="Kassabuch" activePath="cash-book">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h1 style="font-family: 'Fraunces Variable', Georgia, serif; font-size: 2.5rem; font-weight: 400; letter-spacing: -0.02em;">
        Kassabuch
      </h1>
      <p style="color: rgba(253, 251, 244, 0.65); margin-top: 0.5rem;">
        Einnahmen und Ausgaben · {currentMonth}
      </p>
    </div>
    <div style="display: flex; gap: 0.75rem;">
      <button id="export-csv-btn" class="btn-secondary">CSV-Export</button>
      <a href="/admin/cash-book/expense" class="btn-primary">+ Ausgabe erfassen</a>
    </div>
  </div>

  <!-- Saldo-Kacheln -->
  <div class="balance-grid">
    <div class="balance-card" style="border-color: rgba(34, 197, 94, 0.3);">
      <div class="balance-label">Einnahmen</div>
      <div class="balance-value" style="color: #86efac;">€{totalIncome.toFixed(2)}</div>
      <div class="balance-sub">{payments.length} Zahlungseingänge</div>
    </div>
    <div class="balance-card" style="border-color: rgba(239, 68, 68, 0.3);">
      <div class="balance-label">Ausgaben</div>
      <div class="balance-value" style="color: #fca5a5;">€{totalExpenses.toFixed(2)}</div>
      <div class="balance-sub">{expenses.length} Ausgaben erfasst</div>
    </div>
    <div class="balance-card" style={`border-color: ${balance >= 0 ? "rgba(255, 194, 51, 0.3)" : "rgba(239, 68, 68, 0.3)"};`}>
      <div class="balance-label">Saldo</div>
      <div class="balance-value" style={`color: ${balance >= 0 ? "#ffc233" : "#fca5a5"};`}>€{balance.toFixed(2)}</div>
      <div class="balance-sub">Einnahmen − Ausgaben</div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab-btn active" data-tab="income">Einnahmen ({payments.length})</button>
    <button class="tab-btn" data-tab="expense">Ausgaben ({expenses.length})</button>
  </div>

  <!-- Einnahmen-Tabelle -->
  <div class="tab-content" data-tab-content="income">
    {payments.length === 0 ? (
      <div class="empty-state">
        <h3>Noch keine Einnahmen</h3>
        <p>Sobald Buchungen Zahlungen enthalten, erscheinen sie hier automatisch.</p>
      </div>
    ) : (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Datum</th>
              <th>Buchung</th>
              <th>Betrag</th>
              <th>Zahlart</th>
              <th>Notiz</th>
            </tr>
          </thead>
          <tbody>
            {payments.map((p) => (
              <tr>
                <td>{p.payment_date}</td>
                <td>{p.bookings?.customer_name ?? "-"}</td>
                <td style="color: #86efac;">+€{p.amount}</td>
                <td>{p.payment_method}</td>
                <td>{p.notes ?? "-"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Ausgaben-Tabelle -->
  <div class="tab-content" data-tab-content="expense" style="display: none;">
    {expenses.length === 0 ? (
      <div class="empty-state">
        <h3>Noch keine Ausgaben</h3>
        <p>
          Kraftstoff, Wartung, Versicherung und andere Kosten hier erfassen.<br />
          <a href="/admin/cash-book/expense" style="color: #ffc233; text-decoration: underline;">Erste Ausgabe erfassen →</a>
        </p>
      </div>
    ) : (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Datum</th>
              <th>Kategorie</th>
              <th>Beschreibung</th>
              <th>Betrag</th>
              <th>Beleg</th>
            </tr>
          </thead>
          <tbody>
            {expenses.map((e) => (
              <tr>
                <td>{e.expense_date}</td>
                <td><span class="badge">{e.category}</span></td>
                <td>{e.description}</td>
                <td style="color: #fca5a5;">−€{e.amount}</td>
                <td>
                  {e.receipt_url ? (
                    <a href={e.receipt_url} target="_blank" rel="noopener" style="color: #ffc233;">Ansehen</a>
                  ) : "-"}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminShell>

<style>
  .btn-primary {
    padding: 0.75rem 1.25rem;
    background: #ffc233;
    color: #071d30;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-primary:hover { opacity: 0.9; }

  .btn-secondary {
    padding: 0.75rem 1.25rem;
    background: transparent;
    color: #fdfbf4;
    border: 1px solid rgba(253, 251, 244, 0.25);
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .btn-secondary:hover { background: rgba(253, 251, 244, 0.05); }

  .balance-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 768px) {
    .balance-grid { grid-template-columns: 1fr; }
  }
  .balance-card {
    background: rgba(253, 251, 244, 0.04);
    border: 1px solid;
    border-radius: 12px;
    padding: 1.75rem;
  }
  .balance-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(253, 251, 244, 0.5);
    margin-bottom: 0.75rem;
  }
  .balance-value {
    font-family: "Fraunces Variable", Georgia, serif;
    font-size: 2.5rem;
  }
  .balance-sub {
    font-size: 0.8rem;
    color: rgba(253, 251, 244, 0.5);
    margin-top: 0.5rem;
  }

  .tabs {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(253, 251, 244, 0.1);
  }
  .tab-btn {
    padding: 0.75rem 1.25rem;
    background: transparent;
    color: rgba(253, 251, 244, 0.65);
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-size: 0.9rem;
    font-family: inherit;
  }
  .tab-btn.active {
    color: #ffc233;
    border-bottom-color: #ffc233;
  }

  .empty-state {
    background: rgba(255, 194, 51, 0.05);
    border: 1px dashed rgba(255, 194, 51, 0.3);
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
  }
  .empty-state h3 {
    font-family: "Fraunces Variable", Georgia, serif;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: rgba(253, 251, 244, 0.65);
    line-height: 1.6;
  }

  .table-wrap {
    background: rgba(253, 251, 244, 0.04);
    border: 1px solid rgba(253, 251, 244, 0.1);
    border-radius: 12px;
    overflow-x: auto;
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  thead { background: rgba(0, 0, 0, 0.2); }
  th {
    text-align: left;
    padding: 1rem 1.25rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(253, 251, 244, 0.5);
    font-weight: 500;
  }
  td { padding: 1rem 1.25rem; border-top: 1px solid rgba(253, 251, 244, 0.05); }

  .badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.7rem;
    background: rgba(255, 194, 51, 0.1);
    color: #ffc233;
  }
</style>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const tabContents = document.querySelectorAll<HTMLElement>("[data-tab-content]");
  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      tabBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      const tab = btn.dataset.tab;
      tabContents.forEach((c) => {
        (c as HTMLElement).style.display = c.dataset.tabContent === tab ? "block" : "none";
      });
    });
  });

  document.getElementById("export-csv-btn")?.addEventListener("click", async () => {
    alert("CSV-Export wird aktiv sobald Supabase läuft.");
  });
</script>
