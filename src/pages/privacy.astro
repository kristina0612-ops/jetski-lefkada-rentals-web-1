  <script>
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const lang = (btn as HTMLElement).dataset.lang;
        document.querySelectorAll('.lang-block').forEach(block => {
          (block as HTMLElement).style.display = block.getAttribute('data-lang') === lang ? 'block' : 'none';
        });
      });
    });

    // Cookie-Einstellungen erneut anzeigen – triggert das CookieBanner-Component
    document.querySelectorAll('.cookie-reset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('cookie:reset'));
      });
    });
  </script>
