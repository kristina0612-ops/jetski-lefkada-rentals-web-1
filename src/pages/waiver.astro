    <p style="font-size: 0.85rem; color: #6b7a8d;">
      Last updated: April 2026 · Nero Lefkada Rental&amp;Retail · Lygia, Lefkada, Greece<br>
      <em>This document was drafted as a best-practice template and requires review by a qualified Greek lawyer (maritime/tourism law) before legal effect is claimed in court.</em>
    </p>
  </div>

  <script>
    const tabs = document.querySelectorAll('.lang-btn');
    const blocks = document.querySelectorAll('.lang-block');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const lang = tab.getAttribute('data-lang');
        tabs.forEach((t) => t.classList.toggle('active', t.getAttribute('data-lang') === lang));
        blocks.forEach((b) => b.classList.toggle('active', b.getAttribute('data-lang') === lang));
      });
    });
  </script>
</LayoutBare>
