---
// Final CTA section - the closing moment
---

<section class="relative py-24 lg:py-40 overflow-hidden">
  <!-- Background aurora -->
  <div class="absolute inset-0 pointer-events-none opacity-60">
    <div
      class="absolute -top-20 left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full blur-[180px] slow-float"
      style="background: radial-gradient(circle, rgba(255, 90, 54, 0.35), transparent 60%)"
    ></div>
    <div
      class="absolute -bottom-40 left-1/4 w-[700px] h-[700px] rounded-full blur-[160px] slow-float-reverse"
      style="background: radial-gradient(circle, rgba(74, 144, 184, 0.3), transparent 60%)"
    ></div>
  </div>

  <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12 text-center">
    <div class="chapter-numeral text-5xl mb-3">08</div>
    <div class="section-label mb-10 justify-center" style="display: inline-flex;">
      <span>The Final Chapter</span>
    </div>

    <h2 class="display-headline text-5xl lg:text-[clamp(4rem,8vw,9rem)] max-w-[18ch] mx-auto mb-10">
      Your <em>summer</em><br />
      starts <em>here.</em>
    </h2>

    <p class="font-body text-lg lg:text-xl text-paper-200/80 max-w-2xl mx-auto mb-12 leading-relaxed">
      Four jetskis. Six hidden bays. One David Goldberg. And a single sunny
      afternoon you'll remember for the rest of your life.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
      <a href="#fleet" class="btn-coral" data-cro="final-primary-cta">
        Book Your Jetski
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href="https://wa.me/306955612777?text=Hi%20David%2C%20I%20have%20a%20question%20about%20renting%20a%20jetski"
        target="_blank"
        rel="noopener"
        class="btn-ghost"
        data-cro="final-secondary-cta"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.304-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
        </svg>
        Chat with David
      </a>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-8 pt-8 border-t border-brass-500/20 max-w-2xl mx-auto">
      <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-paper-400/80">
        Free cancel 48h
      </div>
      <span class="text-brass-500/40">·</span>
      <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-paper-400/80">
        30% deposit accepted
      </div>
      <span class="text-brass-500/40">·</span>
      <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-paper-400/80">
        instant confirmation
      </div>
    </div>
  </div>
</section>
