---
const usps = [
  {
    number: "01",
    label: "The Book",
    title: "Ninety-second booking",
    body: "Pick a jetski, a date, a duration. Digital waiver, deposit, done. No back-and-forth WhatsApp. No paperwork at arrival.",
    detail: "Powered by Bokun + Viva Wallet. Apple Pay, Google Pay, credit card, PayPal.",
  },
  {
    number: "02",
    label: "The Ride",
    title: "Local captain's briefing",
    body: "David has ridden every cove on Lefkada since 2019. Before you launch, you get ten minutes of the good stuff: where to go, where not to go, what to look for.",
    detail: "Safety gear, life jackets, kill-switch lanyards. Greek Port Authority compliant.",
  },
  {
    number: "03",
    label: "The Return",
    title: "Only what you used",
    body: "Transparent pricing. No hidden surcharges. Fuel-in, fuel-out. Deposit returned the same afternoon. Reviews requested the next morning, only if you want.",
    detail: "Fully insured for third-party liability up to €700.000 per incident.",
  },
];
---

<section class="relative py-24 lg:py-40">
  <div class="mx-auto max-w-[1600px] px-6 lg:px-12">
    <!-- Section header -->
    <div class="grid grid-cols-12 gap-6 mb-20 lg:mb-28">
      <div class="col-span-12 lg:col-span-2">
        <div class="chapter-numeral text-5xl">02</div>
        <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-brass-400 mt-3">
          Chapter 02
        </div>
      </div>
      <div class="col-span-12 lg:col-span-7">
        <div class="section-label mb-6"><span>How we work</span></div>
        <h2 class="display-headline text-4xl lg:text-[clamp(3rem,5vw,5rem)]">
          Three beats. <em>No friction.</em>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-3 flex items-end">
        <p class="font-body text-paper-200/70 text-base leading-relaxed">
          Built for people on vacation, not on paperwork. Every step is designed
          to take less of your day than it takes to read it.
        </p>
      </div>
    </div>

    <!-- USP cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
      {
        usps.map((usp) => (
          <article class="group relative">
            <div class="flex items-baseline justify-between mb-6">
              <div class="chapter-numeral text-4xl">{usp.number}</div>
              <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-brass-400">
                {usp.label}
              </div>
            </div>

            <div class="h-px w-full bg-gradient-to-r from-brass-500/60 via-brass-500/20 to-transparent mb-8 group-hover:from-coral-500/60 transition-colors duration-700" />

            <h3 class="font-display text-3xl lg:text-[2.5rem] leading-tight text-paper-100 mb-6">
              {usp.title}
            </h3>

            <p class="font-body text-base lg:text-lg leading-relaxed text-paper-200/80 mb-6">
              {usp.body}
            </p>

            <p class="font-mono text-[11px] uppercase tracking-[0.12em] text-paper-400/80 leading-relaxed">
              {usp.detail}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
