---
import { jetskis } from "../data/jetskis";
---

<section id="fleet" class="relative py-24 lg:py-36 overflow-hidden">
  <!-- Section header -->
  <div class="mx-auto max-w-[1600px] px-6 lg:px-12 mb-16 lg:mb-20">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-2">
        <div class="chapter-numeral text-5xl">03</div>
        <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-brass-400 mt-3">
          Chapter 03
        </div>
      </div>
      <div class="col-span-12 lg:col-span-7">
        <div class="section-label mb-6"><span>The Fleet · 4 machines</span></div>
        <h2 class="display-headline text-4xl lg:text-[clamp(3rem,5vw,5rem)]">
          Choose your <em>weapon.</em>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-3 flex items-end justify-end gap-3">
        <button
          type="button"
          class="fleet-scroll-btn group w-12 h-12 border border-brass-500/40 hover:border-coral-500 hover:bg-coral-500 transition-colors duration-500 flex items-center justify-center"
          data-direction="prev"
          aria-label="Previous jetski"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-paper-100 group-hover:text-ink-950" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          type="button"
          class="fleet-scroll-btn group w-12 h-12 border border-brass-500/40 hover:border-coral-500 hover:bg-coral-500 transition-colors duration-500 flex items-center justify-center"
          data-direction="next"
          aria-label="Next jetski"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-paper-100 group-hover:text-ink-950" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Horizontal scroll rail -->
  <div
    id="fleet-rail"
    class="snap-x-fleet flex gap-6 lg:gap-10 overflow-x-auto pb-10 px-6 lg:px-12 scroll-smooth"
  >
    {
      jetskis.map((js, i) => {
        const isFeatured = i === 1;
        const scarcity =
          js.availableToday === 0
            ? "Fully booked today"
            : js.availableToday === 1
              ? `Only 1 left today`
              : `${js.availableToday} of ${js.totalUnits} available`;
        const scarcityColor =
          js.availableToday === 0
            ? "text-paper-400"
            : js.availableToday === 1
              ? "text-coral-500"
              : "text-green-400";

        return (
          <article
            class:list={[
              "group relative shrink-0 w-[84vw] md:w-[62vw] lg:w-[44vw] xl:w-[36vw] 2xl:w-[32rem]",
              "bg-ink-900/70 border border-brass-500/20 backdrop-blur-sm",
              "hover:border-coral-500/50 transition-all duration-700",
              isFeatured && "glow-border",
            ]}
          >
            {/* Number & label */}
            <div class="flex items-center justify-between px-7 pt-7">
              <div class="chapter-numeral text-3xl">{String(i + 1).padStart(2, "0")}</div>
              {isFeatured && (
                <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-coral-500 border border-coral-500/50 px-2 py-1">
                  Most popular
                </div>
              )}
            </div>

            {/* Image */}
            <div class="relative mt-4 mx-7 h-64 lg:h-72 overflow-hidden bg-ink-800">
              <img
                src={js.image}
                alt={`${js.brand} ${js.model}`}
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 grayscale-[40%] group-hover:grayscale-0"
                loading={i < 2 ? "eager" : "lazy"}
                style="filter: contrast(1.1) brightness(0.85) saturate(1.1);"
              />
              {/* Overlay grade */}
              <div
                class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-60"
                style={`background: linear-gradient(135deg, transparent, ${js.accent}40)`}
              ></div>
              <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-ink-900/80 to-transparent"></div>
              {/* Price pill top-right */}
              <div class="absolute top-4 right-4 bg-ink-950/80 backdrop-blur-sm border border-brass-500/40 px-3 py-1.5">
                <span class="font-display text-coral-500 text-lg leading-none">€{js.pricePerHour}</span>
                <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-paper-400 ml-1">/hr</span>
              </div>
            </div>

            {/* Content */}
            <div class="p-7">
              <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-brass-400 mb-2">
                {js.brand} · {js.model} · {js.year}
              </div>
              <h3 class="font-display text-3xl text-paper-100 mb-1">{js.name}</h3>
              <p class="font-display italic text-paper-400 text-lg mb-6">{js.tagline}</p>

              {/* Specs row */}
              <div class="grid grid-cols-4 gap-2 border-y border-brass-500/20 py-4 mb-6">
                <div>
                  <div class="font-display text-xl text-paper-100">{js.hp}</div>
                  <div class="font-mono text-[9px] uppercase tracking-[0.12em] text-brass-400">HP</div>
                </div>
                <div>
                  <div class="font-display text-xl text-paper-100">{js.topSpeed}</div>
                  <div class="font-mono text-[9px] uppercase tracking-[0.12em] text-brass-400">km/h</div>
                </div>
                <div>
                  <div class="font-display text-xl text-paper-100">{js.seats}</div>
                  <div class="font-mono text-[9px] uppercase tracking-[0.12em] text-brass-400">Seats</div>
                </div>
                <div>
                  <div class="font-display text-xl text-paper-100">{js.year}</div>
                  <div class="font-mono text-[9px] uppercase tracking-[0.12em] text-brass-400">Year</div>
                </div>
              </div>

              {/* Features */}
              <ul class="space-y-1.5 mb-6">
                {js.features.map((f) => (
                  <li class="font-mono text-[11px] uppercase tracking-[0.08em] text-paper-200/70 flex items-center gap-2">
                    <span class="w-1 h-1 bg-brass-500"></span>
                    {f}
                  </li>
                ))}
              </ul>

              {/* Price grid */}
              <div class="grid grid-cols-3 gap-2 mb-6 text-center">
                <div class="py-3 border border-brass-500/20">
                  <div class="font-mono text-[9px] uppercase tracking-[0.12em] text-brass-400">1 hour</div>
                  <div class="font-display text-lg text-paper-100 mt-1">€{js.pricePerHour}</div>
                </div>
                <div class="py-3 border border-brass-500/20">
                  <div class="font-mono text-[9px] uppercase tracking-[0.12em] text-brass-400">Half day</div>
                  <div class="font-display text-lg text-paper-100 mt-1">€{js.priceHalfDay}</div>
                </div>
                <div class="py-3 border border-brass-500/20">
                  <div class="font-mono text-[9px] uppercase tracking-[0.12em] text-brass-400">Full day</div>
                  <div class="font-display text-lg text-paper-100 mt-1">€{js.priceFullDay}</div>
                </div>
              </div>

              {/* Scarcity + CTA */}
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                  <span class="relative flex h-2 w-2">
                    {js.availableToday > 0 && (
                      <span class:list={["absolute inline-flex h-full w-full rounded-full opacity-75", js.availableToday === 1 ? "bg-coral-500" : "bg-green-400"]} style="animation: pulse-dot 2s ease-in-out infinite;"></span>
                    )}
                    <span class:list={["relative inline-flex rounded-full h-2 w-2", js.availableToday === 0 ? "bg-paper-600" : js.availableToday === 1 ? "bg-coral-500" : "bg-green-400"]}></span>
                  </span>
                  <span class:list={["font-mono text-[10px] uppercase tracking-[0.12em]", scarcityColor]}>
                    {scarcity}
                  </span>
                </div>
                <a
                  href={`#book-${js.id}`}
                  class:list={[
                    "font-mono text-[10px] uppercase tracking-[0.18em] px-4 py-2.5 transition-all duration-500",
                    js.availableToday === 0
                      ? "border border-paper-600/40 text-paper-600 cursor-not-allowed pointer-events-none"
                      : "bg-coral-500 text-ink-950 hover:bg-coral-400",
                  ]}
                  data-cro={`fleet-book-${js.id}`}
                >
                  {js.availableToday === 0 ? "Waitlist" : "Book"}
                  {js.availableToday > 0 && " →"}
                </a>
              </div>
            </div>
          </article>
        );
      })
    }
  </div>

  <script>
    const rail = document.getElementById("fleet-rail");
    const buttons = document.querySelectorAll(".fleet-scroll-btn");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (!rail) return;
        const direction = (btn as HTMLElement).dataset.direction;
        const delta = rail.clientWidth * 0.7;
        rail.scrollBy({ left: direction === "next" ? delta : -delta, behavior: "smooth" });
      });
    });
  </script>
</section>
