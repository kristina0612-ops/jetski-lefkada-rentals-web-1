---
import { jetskis, pricingExtras } from "../../data/jetskis";

// Smallest Beach Ride price used for "from €X · 10 min" hint.
const fromPrice = Math.min(...jetskis.map((j) => j.beachRides.min10 ?? 80));
const seatsNote = pricingExtras.seatsNote.en;
---

<section id="fleet" class="relative py-24 lg:py-40" style="background: var(--v2-cream-50);">
  <div class="mx-auto max-w-[1600px] px-6 lg:px-12">
    <!-- Header -->
    <div class="grid grid-cols-12 gap-6 mb-16 lg:mb-24">
      <div class="col-span-12 lg:col-span-8">
        <div class="v2-eyebrow mb-6"><span>The Fleet · 4× Sea-Doo Supercharged</span></div>
        <h2 class="v2-display text-5xl lg:text-[clamp(3.5rem,6vw,6.5rem)]">
          Pick your <em>weapon.</em><br />Then ride it.
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-4 flex items-end">
        <p class="text-lg leading-relaxed max-w-md" style="color: rgba(7,29,48,0.75);">
          Every Sea-Doo is cleaned, fueled and ready within 15 minutes of your
          booking window. Live availability updates in real time.
        </p>
      </div>
    </div>

    <!-- Bento grid - asymmetric, 4 cards -->
    <div class="grid grid-cols-12 gap-6 lg:gap-8">
      {
        jetskis.map((js, i) => {
          const spans = [
            "col-span-12 lg:col-span-7",
            "col-span-12 lg:col-span-5",
            "col-span-12 lg:col-span-5",
            "col-span-12 lg:col-span-7",
          ];
          const badge = js.featured ? "2026 · Supercharged · Flagship" : "2026 · Supercharged";
          const whatsappText = encodeURIComponent(
            `Hi David, I'd like to book the ${js.name} (${js.brand} ${js.model}). Could I get today's price and availability?`
          );
          return (
            <article
              class:list={["group v2-spotlight", spans[i]]}
              data-spotlight
            >
              <div class="grid grid-cols-5 h-full">
                {/* Image */}
                <div class="col-span-5 md:col-span-3 relative overflow-hidden min-h-[360px]">
                  <img
                    src={js.image}
                    alt={`${js.name} – ${js.brand} ${js.model}`}
                    width="1400"
                    height="933"
                    loading={i < 2 ? "eager" : "lazy"}
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-110"
                  />
                  <div class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-30" style={`background: linear-gradient(135deg, transparent, ${js.accent})`}></div>
                  {js.featured && (
                    <div class="absolute top-5 left-5 px-3 py-1.5 rounded-full" style="background: var(--v2-sun-400); color: var(--v2-ink-950);">
                      <span class="font-mono text-[10px] uppercase tracking-[0.14em] font-semibold">★ Flagship</span>
                    </div>
                  )}
                  {/* Availability dot */}
                  <div class="absolute bottom-5 left-5 flex items-center gap-2 px-3 py-1.5 rounded-full backdrop-blur-md" style="background: rgba(253,251,244,0.9);">
                    <span class="relative flex h-2 w-2">
                      {js.availableToday > 0 && (
                        <span class:list={["absolute inline-flex h-full w-full rounded-full opacity-75", js.availableToday === 1 ? "bg-orange-500" : "bg-green-500"]} style="animation: pulse-dot 2s ease-in-out infinite;"></span>
                      )}
                      <span class:list={["relative inline-flex rounded-full h-2 w-2", js.availableToday === 0 ? "bg-gray-400" : js.availableToday === 1 ? "bg-orange-500" : "bg-green-500"]}></span>
                    </span>
                    <span class="font-mono text-[10px] uppercase tracking-[0.12em] font-semibold" style="color: var(--v2-ink-900);">
                      {js.availableToday === 0 ? "Booked out" : `${js.availableToday} left today`}
                    </span>
                  </div>
                </div>

                {/* Content */}
                <div class="col-span-5 md:col-span-2 p-7 lg:p-9 flex flex-col justify-between" style="background: var(--v2-cream-100);">
                  <div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.18em] mb-2" style="color: var(--v2-turquoise-600);">
                      {js.brand} · {js.year}
                    </div>
                    <h3 class="font-display text-3xl lg:text-4xl leading-none mb-1" style="color: var(--v2-ink-950);">{js.name}</h3>
                    <div class="font-mono text-[11px] uppercase tracking-[0.12em] mb-3" style="color: rgba(7,29,48,0.55);">{js.model}</div>
                    <p class="font-display italic text-lg mb-5" style="color: rgba(7,29,48,0.6);">{js.tagline}</p>

                    {/* Specs */}
                    <div class="grid grid-cols-3 gap-3 mb-3">
                      <div>
                        <div class="font-display text-2xl" style="color: var(--v2-ink-950);">{js.hp}</div>
                        <div class="font-mono text-[9px] uppercase tracking-[0.12em]" style="color: var(--v2-turquoise-600);">HP</div>
                      </div>
                      <div>
                        <div class="font-display text-2xl" style="color: var(--v2-ink-950);">{js.topSpeed}</div>
                        <div class="font-mono text-[9px] uppercase tracking-[0.12em]" style="color: var(--v2-turquoise-600);">km/h</div>
                      </div>
                      <div>
                        <div class="font-display text-2xl" style="color: var(--v2-ink-950);">{js.seats}<span class="text-xs align-top" style="color: var(--v2-turquoise-600);">*</span></div>
                        <div class="font-mono text-[9px] uppercase tracking-[0.12em]" style="color: var(--v2-turquoise-600);">Seats</div>
                      </div>
                    </div>
                    <div class="font-mono text-[9px] italic mb-5" style="color: rgba(7,29,48,0.5);">{seatsNote}</div>

                    {/* Badge */}
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6" style="background: rgba(0,179,167,0.1); color: var(--v2-turquoise-600);">
                      <span class="font-mono text-[10px] uppercase tracking-[0.14em] font-semibold">{badge}</span>
                    </div>
                  </div>

                  <div>
                    {/* Pricing */}
                    <div class="mb-4">
                      <div class="flex items-baseline gap-1">
                        <span class="font-mono text-[10px] uppercase tracking-[0.18em]" style="color: var(--v2-turquoise-600);">from</span>
                        <span class="v2-display text-4xl v2-gradient-sun">€{js.beachRides.min10}</span>
                        <span class="font-mono text-[10px] uppercase tracking-[0.18em]" style="color: var(--v2-turquoise-600);">· 10 min</span>
                      </div>
                      <a href="#booking-form" class="inline-flex items-center gap-1.5 mt-1 font-mono text-[10px] uppercase tracking-[0.14em] hover:opacity-70 transition-opacity" style="color: var(--v2-ink-900);">
                        <span>See all prices</span>
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                          <path d="M12 5v14M5 12l7 7 7-7"/>
                        </svg>
                      </a>
                    </div>

                    <a
                      href={js.availableToday === 0
                        ? "#book"
                        : `https://wa.me/306955612777?text=${whatsappText}`}
                      target={js.availableToday === 0 ? "_self" : "_blank"}
                      rel={js.availableToday === 0 ? "" : "noopener"}
                      class:list={[
                        "inline-flex items-center justify-center w-full py-3 rounded-full font-mono text-[11px] uppercase tracking-[0.14em] font-semibold transition-all duration-500",
                        js.availableToday === 0
                          ? "opacity-50 cursor-not-allowed pointer-events-none"
                          : "hover:scale-[1.02]",
                      ]}
                      style={js.availableToday === 0
                        ? "background: rgba(7,29,48,0.1); color: rgba(7,29,48,0.5);"
                        : "background: var(--v2-ink-950); color: var(--v2-cream-50);"}
                      data-cro={`v2-fleet-whatsapp-${js.id}`}
                    >
                      {js.availableToday === 0 ? "Join waitlist" : "WhatsApp to book"}
                      {js.availableToday > 0 && (
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="ml-2" aria-hidden="true">
                          <path d="M5 12h14M13 5l7 7-7 7"/>
                        </svg>
                      )}
                    </a>
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    {/* Fleet footnote */}
    <p class="mt-8 text-xs italic text-center" style="color: rgba(7,29,48,0.5);">{seatsNote}</p>
  </div>

  <script>
    // Spotlight pointer tracking (21st.dev pattern)
    const cards = document.querySelectorAll<HTMLElement>("[data-spotlight]");
    cards.forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        card.style.setProperty("--mx", `${x}%`);
        card.style.setProperty("--my", `${y}%`);
      });
    });
  </script>
</section>
