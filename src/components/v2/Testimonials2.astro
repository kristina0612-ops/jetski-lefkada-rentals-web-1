---
import { testimonials } from "../../data/testimonials";
---

<section id="voices" class="relative py-24 lg:py-40" style="background: var(--v2-ink-950); color: var(--v2-cream-50);">
  <div class="mx-auto max-w-[1600px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 lg:col-span-8">
        <div class="v2-eyebrow mb-6" style="color: var(--v2-sun-300);"><span>327 voices · 4.9 stars</span></div>
        <h2 class="v2-display text-5xl lg:text-[clamp(3.5rem,6vw,6.5rem)]" style="color: var(--v2-cream-50);">
          They came.<br /><em class="v2-gradient-sun">They returned.</em>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-4 flex items-end justify-end">
        <div class="flex items-baseline gap-4">
          <span class="v2-display text-7xl lg:text-8xl v2-gradient-sun">4.9</span>
          <div class="font-mono text-[10px] uppercase tracking-[0.18em] leading-relaxed" style="color: rgba(253,251,244,0.6);">
            TripAdvisor<br />Google<br />Viator
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        testimonials.map((t, i) => (
          <article
            class:list={[
              "group relative p-8 lg:p-10 rounded-3xl transition-all duration-500",
              i === 0 && "md:col-span-2 lg:col-span-1",
            ]}
            style="background: rgba(253,251,244,0.04); border: 1px solid rgba(253,251,244,0.1);"
          >
            <div class="flex items-center gap-1 mb-6">
              {Array.from({ length: t.rating }).map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" style="fill: var(--v2-sun-400);" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <blockquote class="font-display text-2xl leading-snug mb-8" style="color: var(--v2-cream-50);">
              "{t.quote}"
            </blockquote>
            <footer class="pt-6 border-t flex items-center justify-between" style="border-color: rgba(253,251,244,0.1);">
              <div>
                <div class="font-body text-sm font-medium" style="color: var(--v2-cream-50);">{t.author}</div>
                <div class="font-mono text-[10px] uppercase tracking-[0.14em] mt-1" style="color: rgba(253,251,244,0.5);">
                  {t.origin}
                </div>
              </div>
              <div class="font-mono text-[9px] uppercase tracking-[0.18em]" style="color: var(--v2-sun-300);">
                {t.source}
              </div>
            </footer>
          </article>
        ))
      }
    </div>
  </div>
</section>
