---
// V2 Hero - Azure Day with full-screen jetski video background
---

<section class="relative min-h-[100svh] overflow-hidden flex items-end">
  <!-- Video background -->
  <div class="absolute inset-0 z-0 bg-ink-950">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="w-full h-full object-cover"
      poster="https://images.unsplash.com/photo-1625194398019-62a5362c1e52?w=1920&q=85&auto=format&fit=crop"
      aria-hidden="true"
    >
      <source src="https://assets.mixkit.co/videos/11943/11943-720.mp4" type="video/mp4" />
      <source src="https://assets.mixkit.co/videos/20399/20399-720.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Multi-layer gradient overlay for text legibility -->
  <div class="absolute inset-0 z-10 pointer-events-none">
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(7,29,48,0.85) 0%, rgba(7,29,48,0.3) 25%, rgba(7,29,48,0.2) 60%, rgba(7,29,48,0.95) 100%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, transparent 40%, rgba(7,29,48,0.7) 100%);"></div>
    <!-- Warm color bleed for mediterranean feel -->
    <div class="absolute inset-0 mix-blend-overlay opacity-60" style="background: radial-gradient(ellipse at 80% 20%, #ffc233, transparent 55%);"></div>
  </div>

  <!-- Decorative sun (rotating slow) -->
  <div class="absolute top-24 right-[8%] z-10 w-32 h-32 lg:w-40 lg:h-40 opacity-60 pointer-events-none v2-sun hidden md:block">
    <svg viewBox="0 0 160 160" class="w-full h-full" aria-hidden="true">
      <defs>
        <radialGradient id="sunGrad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#ffd76a" />
          <stop offset="100%" stop-color="#ffaa00" />
        </radialGradient>
      </defs>
      <circle cx="80" cy="80" r="22" fill="url(#sunGrad)"/>
      <g stroke="#ffd76a" stroke-width="2" stroke-linecap="round">
        <line x1="80" y1="10" x2="80" y2="30"/>
        <line x1="80" y1="130" x2="80" y2="150"/>
        <line x1="10" y1="80" x2="30" y2="80"/>
        <line x1="130" y1="80" x2="150" y2="80"/>
        <line x1="30" y1="30" x2="44" y2="44"/>
        <line x1="116" y1="116" x2="130" y2="130"/>
        <line x1="30" y1="130" x2="44" y2="116"/>
        <line x1="116" y1="44" x2="130" y2="30"/>
      </g>
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-20 w-full pt-32 pb-16 lg:pb-20">
    <div class="mx-auto max-w-[1600px] px-6 lg:px-12">
      <div class="v2-reveal max-w-5xl">
        <div class="v2-eyebrow mb-8" style="color: var(--v2-sun-300);">
          <span>Lefkada · Greece · Summer 2026</span>
        </div>

        <h1 class="v2-display text-5xl md:text-6xl lg:text-[clamp(4.5rem,9vw,10rem)]" style="color: var(--v2-cream-50);">
          Ride the<br />
          <span class="v2-gradient-sun"><em>Ionian</em></span><br />
          <span class="text-[0.75em]">like a local.</span>
        </h1>

        <p class="mt-10 max-w-xl text-lg lg:text-xl leading-relaxed" style="color: rgba(253,251,244,0.85);">
          Premium Sea-Doo jetskis. A hand-drawn map of the island's best secret
          coves. And Kristina &amp; David Goldberg – a family run business
          waiting at the marina with a ten-minute briefing and a throttle
          cable that begs to be pulled.
        </p>

        <div class="mt-12 flex flex-wrap items-center gap-4">
          <a href="#fleet" class="v2-btn" data-cro="v2-hero-primary">
            Check availability
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="https://wa.me/306955612777"
            target="_blank"
            rel="noopener"
            class="v2-btn-ghost"
            style="color: var(--v2-cream-50); border-color: var(--v2-cream-50);"
            data-cro="v2-hero-whatsapp"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.304-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
            </svg>
            Chat with David
          </a>
        </div>

        <!-- Stats Bar -->
        <div class="mt-16 pt-8 border-t border-white/15 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl">
          {
            [
              { n: "1,000+", l: "Happy riders" },
              { n: "€70", l: "From per hour" },
              { n: "1-click", l: "WhatsApp booking" },
            ].map((stat) => (
              <div>
                <div class="v2-display text-4xl lg:text-5xl" style="color: var(--v2-sun-300);">
                  {stat.n}
                </div>
                <div class="font-mono text-[10px] uppercase tracking-[0.18em] mt-2" style="color: rgba(253,251,244,0.65);">
                  {stat.l}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Animated waves bottom -->
  <div class="absolute bottom-0 left-0 right-0 z-10 pointer-events-none h-24 overflow-hidden">
    <svg class="w-full h-full" viewBox="0 0 1440 100" preserveAspectRatio="none" aria-hidden="true">
      <path
        fill="#071d30"
        d="M0,60 C240,100 480,20 720,50 C960,80 1200,20 1440,40 L1440,100 L0,100 Z"
      >
        <animate
          attributeName="d"
          dur="8s"
          repeatCount="indefinite"
          values="
            M0,60 C240,100 480,20 720,50 C960,80 1200,20 1440,40 L1440,100 L0,100 Z;
            M0,50 C240,20 480,90 720,60 C960,30 1200,80 1440,50 L1440,100 L0,100 Z;
            M0,60 C240,100 480,20 720,50 C960,80 1200,20 1440,40 L1440,100 L0,100 Z
          "
        />
      </path>
    </svg>
  </div>
</section>
