---
const links = [
  { href: "#fleet", label: "Fleet" },
  { href: "#water-fun", label: "Water Fun" },
  { href: "#how", label: "How it works" },
  { href: "#faq", label: "FAQ" },
];
---

<style>
  #mobile-nav {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s ease;
  }
  #mobile-nav[data-open] {
    transform: translateX(0) !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* Hamburger → X animation */
  #nav-toggle[aria-expanded="true"] .nav-bar-1 {
    transform: rotate(45deg) translate(4.5px, 4.5px);
  }
  #nav-toggle[aria-expanded="true"] .nav-bar-2 {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-toggle[aria-expanded="true"] .nav-bar-3 {
    transform: rotate(-45deg) translate(4.5px, -4.5px);
  }

  .nav-bar-1,
  .nav-bar-2,
  .nav-bar-3 {
    transition: transform 0.3s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  /* Mobile nav link hover */
  .mob-link {
    transition: color 0.3s ease, transform 0.3s ease;
  }
  .mob-link:hover {
    color: var(--v2-sun-400);
    transform: translateX(8px);
  }
</style>

<nav class="absolute top-0 left-0 right-0 z-40 pointer-events-none pt-16">
  <div class="pointer-events-auto mx-auto max-w-[1600px] px-6 lg:px-12 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-3" aria-label="Jetski Lefkada Rentals home">
      <span class="relative inline-flex items-center justify-center w-11 h-11 rounded-full" style="background: var(--v2-sun-400); color: var(--v2-ink-950);">
        <span class="font-display italic text-xl leading-none">J</span>
      </span>
      <div class="hidden sm:flex flex-col leading-none">
        <span class="font-display text-xl tracking-tight" style="color: var(--v2-cream-50);">Jetski Lefkada</span>
      </div>
    </a>

    <!-- Center pills (desktop only) -->
    <div class="hidden md:flex items-center gap-1 rounded-full p-1.5 border backdrop-blur-md" style="background: rgba(7,29,48,0.4); border-color: rgba(253,251,244,0.18);">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="px-5 py-2 font-mono text-[10px] uppercase tracking-[0.14em] rounded-full transition-all duration-500"
            style="color: rgba(253,251,244,0.85);"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <!-- Right side: Instagram + CTA + Hamburger -->
    <div class="flex items-center gap-3">
      <!-- Instagram (desktop only, icon-only) -->
      <a
        href="https://instagram.com/jetski__lefkada"
        target="_blank"
        rel="noopener"
        class="hidden md:inline-flex items-center justify-center w-11 h-11 rounded-full border transition-all duration-300 hover:scale-110"
        style="border-color: rgba(253,251,244,0.25); color: var(--v2-cream-50); background: rgba(253,251,244,0.05);"
        aria-label="Follow @jetski__lefkada on Instagram"
        data-cro="navbar-instagram"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.849.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.849.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>

      <!-- CTA (always visible) -->
      <a
        href="#fleet"
        class="v2-btn !py-3 !px-5 !text-xs"
        style="background: var(--v2-sun-400); color: var(--v2-ink-950);"
      >
        Book Now
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Hamburger button (mobile only) -->
      <button
        id="nav-toggle"
        class="md:hidden flex flex-col justify-center items-center gap-[5px] w-11 h-11 rounded-full backdrop-blur-md border"
        style="background: rgba(7,29,48,0.4); border-color: rgba(253,251,244,0.18);"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="nav-bar-1 block w-5 h-[1.5px]" style="background: var(--v2-cream-50);"></span>
        <span class="nav-bar-2 block w-5 h-[1.5px]" style="background: var(--v2-cream-50);"></span>
        <span class="nav-bar-3 block w-5 h-[1.5px]" style="background: var(--v2-cream-50);"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile navigation drawer -->
<div
  id="mobile-nav"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
  class="fixed inset-0 z-50 md:hidden flex flex-col"
  style="background: var(--v2-ink-950, #071d30); transform: translateX(100%); opacity: 0; pointer-events: none;"
>
  <!-- Decorative glow -->
  <div class="absolute bottom-0 right-0 w-80 h-80 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(0,179,167,0.08), transparent 70%);"></div>
  <div class="absolute top-1/3 left-0 w-64 h-64 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(255,215,106,0.05), transparent 70%);"></div>

  <!-- Header row -->
  <div class="relative flex items-center justify-between px-6 pt-12 pb-6 border-b" style="border-color: rgba(253,251,244,0.1);">
    <a href="/" class="flex items-center gap-3" onclick="closeNav()">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full" style="background: var(--v2-sun-400, #ffc233); color: var(--v2-ink-950, #071d30);">
        <span class="font-display italic text-lg leading-none">J</span>
      </span>
      <span class="font-display text-lg tracking-tight" style="color: var(--v2-cream-50, #fdfbf4);">Jetski Lefkada</span>
    </a>
    <button
      id="nav-close"
      class="flex items-center justify-center w-11 h-11 rounded-full border backdrop-blur-md"
      style="background: rgba(253,251,244,0.05); border-color: rgba(253,251,244,0.18); color: var(--v2-cream-50, #fdfbf4);"
      aria-label="Close navigation"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Nav links (centered) -->
  <nav class="relative flex-1 flex flex-col justify-center px-8 gap-2">
    {
      links.map((l, i) => (
        <a
          href={l.href}
          class="mob-link font-display text-5xl py-3"
          style={`color: rgba(253,251,244,0.85); animation-delay: ${i * 0.05}s;`}
        >
          {l.label}
        </a>
      ))
    }
  </nav>

  <!-- Footer CTA -->
  <div class="relative px-6 pb-12 pt-6 border-t" style="border-color: rgba(253,251,244,0.1);">
    <a
      href="#fleet"
      class="v2-btn w-full justify-center !py-4 !text-sm"
      style="background: var(--v2-sun-400, #ffc233); color: var(--v2-ink-950, #071d30);"
    >
      Book your jetski
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>
    <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-center mt-4" style="color: rgba(253,251,244,0.35);">
      Nidri · Lefkada · May–Sep
    </p>
  </div>
</div>

<script>
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('mobile-nav');
  const closeBtn = document.getElementById('nav-close');

  function openNav() {
    drawer.setAttribute('data-open', '');
    toggle.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
  }

  function closeNav() {
    drawer.removeAttribute('data-open');
    toggle.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    drawer.hasAttribute('data-open') ? closeNav() : openNav();
  });

  closeBtn.addEventListener('click', closeNav);

  // Close on any nav link tap
  drawer.querySelectorAll('a').forEach(link => link.addEventListener('click', closeNav));

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.hasAttribute('data-open')) closeNav();
  });
</script>
