---
// Gallery2, Real customer moments (2025 season, consent confirmed by Kristina 2026-04-19)
// All photos: `public/images/customers/` + `public/images/gallery/`, stored locally.
// Privacy: All depicted persons gave written consent, see privacy.astro §10.
// Kristina can re-arrange the selection by changing the `src` paths below.
//
// Quality note (2026-04-20): Phone-shot photos look slightly soft on laptop.
// Same CSS filter + SVG unsharp-mask approach as Hero2 is applied to perceive
// the images as sharper without re-encoding. Milder kernel than Hero because
// still images don't need motion-blur compensation.
// Card-selection updated 2026-04-20 per Kristina:
// • Trimmed to exactly 4 cards, the previous two tiny thumbnails at the
//   bottom of the section (Muscle flex + Tube moment) are gone. The
//   remaining four use the 7-5 / 5-7 asymmetric bento cleanly.
// • Kept: Group ride, Couple on the bay, Family time, Thumbs up.
// • Add-on "Tube moment" moves to the dedicated Water Fun block in the
//   Booking section, so the promo stays on the site, just not in Gallery.
//
// IMPORTANT: See .claude/skills/image-asset-usage/SKILL.md for the
// canonical usage map. Before using any photo here, check that skill.

type Lang = "en" | "de" | "gr";
const lang: Lang = (Astro.props.lang as Lang) ?? "en";

const COPY = {
  en: {
    eyebrow: "Real riders · Real moments",
    titleLead: "The day",
    titleAccent: "you’ll remember.",
    intro: "Real photos from the 2025 season. Every person here gave us permission to share their smile. Yours could be next.",
    consent: "All guests depicted have given written consent for publication. See privacy policy for withdrawal options.",
    moments: [
      { title: "Group ride", caption: "Three jetskis, one crew, endless bay", tag: "Group · Lygia" },
      { title: "Couple on the bay", caption: "Sunglasses, smiles, and a full tank", tag: "Couple ride" },
      { title: "Family time", caption: "Thumbs up from dad and son", tag: "Family" },
      { title: "Thumbs up", caption: "Victory signs, peace signs, whatever fits", tag: "Solo" },
    ],
  },
  de: {
    eyebrow: "Echte Fahrer · Echte Momente",
    titleLead: "Der Tag,",
    titleAccent: "den Du nie vergisst.",
    intro: "Echte Fotos aus der Saison 2025. Jede Person hier hat uns die Erlaubnis gegeben, ihr Lächeln zu zeigen. Deins könnte als Nächstes kommen.",
    consent: "Alle abgebildeten Gäste haben schriftlich zugestimmt. Widerrufsmöglichkeiten in der Datenschutzerklärung.",
    moments: [
      { title: "Gruppenfahrt", caption: "Drei Jetskis, eine Crew, endlose Bucht", tag: "Gruppe · Lygia" },
      { title: "Paar auf dem Wasser", caption: "Sonnenbrille, Lächeln, voller Tank", tag: "Paar-Fahrt" },
      { title: "Familienzeit", caption: "Daumen hoch von Papa und Sohn", tag: "Familie" },
      { title: "Daumen hoch", caption: "Siegeszeichen, Peace-Zeichen, was auch immer passt", tag: "Solo" },
    ],
  },
  gr: {
    eyebrow: "Real riders · Real moments",
    titleLead: "The day",
    titleAccent: "you’ll remember.",
    intro: "Real photos from the 2025 season. Every person here gave us permission to share their smile. Yours could be next.",
    consent: "All guests depicted have given written consent for publication. See privacy policy for withdrawal options.",
    moments: [
      { title: "Group ride", caption: "Three jetskis, one crew, endless bay", tag: "Group · Lygia" },
      { title: "Couple on the bay", caption: "Sunglasses, smiles, and a full tank", tag: "Couple ride" },
      { title: "Family time", caption: "Thumbs up from dad and son", tag: "Family" },
      { title: "Thumbs up", caption: "Victory signs, peace signs, whatever fits", tag: "Solo" },
    ],
  },
}[lang];

const moments = [
  { title: COPY.moments[0].title, caption: COPY.moments[0].caption, tag: COPY.moments[0].tag, src: "/images/customers/nero-guest-12.jpg" },
  { title: COPY.moments[1].title, caption: COPY.moments[1].caption, tag: COPY.moments[1].tag, src: "/images/customers/nero-guest-05.jpg" },
  { title: COPY.moments[2].title, caption: COPY.moments[2].caption, tag: COPY.moments[2].tag, src: "/images/customers/nero-guest-02.jpg" },
  { title: COPY.moments[3].title, caption: COPY.moments[3].caption, tag: COPY.moments[3].tag, src: "/images/customers/nero-guest-07.jpg" },
];
---

<style>
  /* Perceptual sharpening for phone-shot customer photos.
     Base filter works in all browsers; SVG unsharp-mask as progressive enhancement. */
  .gallery-img-crisp {
    filter: contrast(1.1) saturate(1.18) brightness(1.02);
    filter: contrast(1.1) saturate(1.18) brightness(1.02) url(#gallery-sharpen);
    image-rendering: auto; /* let browser use high-quality sampling for still images */
    will-change: filter;
  }
</style>

<!-- Scoped SVG unsharp-mask. Milder than Hero kernel (center 2.6 vs 3) because
     still photos should not exaggerate JPEG-artifact edges. -->
<svg aria-hidden="true" focusable="false" style="position: absolute; width: 0; height: 0; overflow: hidden;">
  <filter id="gallery-sharpen" color-interpolation-filters="sRGB">
    <feConvolveMatrix
      order="3"
      preserveAlpha="true"
      kernelMatrix="0 -0.4 0  -0.4 2.6 -0.4  0 -0.4 0"
    />
  </filter>
</svg>

<section class="relative py-24 lg:py-40" style="background: var(--v2-cream-50);">
  <div class="mx-auto max-w-[1600px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-6 mb-16 lg:mb-20">
      <div class="col-span-12 lg:col-span-8">
        <div class="v2-eyebrow mb-6"><span>{COPY.eyebrow}</span></div>
        <h2 class="v2-display text-5xl lg:text-[clamp(3.5rem,6vw,6.5rem)]">
          {COPY.titleLead}<br /><em>{COPY.titleAccent}</em>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-4 flex items-end">
        <p class="text-lg leading-relaxed" style="color: rgba(7,29,48,0.7);">
          {COPY.intro}
        </p>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-2 lg:gap-3 md:auto-rows-fr">
      {
        moments.map((m, i) => {
          // 4-Card asymmetric bento (7-5 on row 1, 5-7 on row 2).
          // Mobile: jede Karte bekommt ihre eigene aspect-ratio (16/9 bzw 4/5)
          //         und stapelt als col-span-12 untereinander.
          // Desktop: alle 4 Karten bekommen dieselbe fixe Höhe (md:h-[480px])
          //         und aspect-auto, damit liegen beide Paare nebeneinander
          //         auf gleicher Höhe, keine Lücke unter der Zeile.
          //         (2026-04-20 Abend-Fix, vorher standen schmale Karten
          //         auf aspect-[4/5] und breite auf h-full, was die Zeilen
          //         auf Desktop mit Whitespace unter der kleineren Karte
          //         auseinandergerissen hat.)
          const spans = [
            "col-span-12 md:col-span-7 aspect-[16/9] md:aspect-auto md:h-[480px]",
            "col-span-12 md:col-span-5 aspect-[4/5] md:aspect-auto md:h-[480px]",
            "col-span-12 md:col-span-5 aspect-[4/5] md:aspect-auto md:h-[480px]",
            "col-span-12 md:col-span-7 aspect-[16/9] md:aspect-auto md:h-[480px]",
          ];
          return (
            <figure class:list={["group relative overflow-hidden rounded-3xl", spans[i]]}>
              <img
                src={m.src}
                alt={`${m.title}, ${m.caption}`}
                width="1400"
                height="933"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105 gallery-img-crisp"
              />
              <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(7,29,48,0.85), transparent 50%);"></div>
              <div class="absolute top-5 right-5 px-3 py-1.5 rounded-full backdrop-blur-md font-mono text-[10px] uppercase tracking-[0.14em]" style="background: rgba(253,251,244,0.9); color: var(--v2-ink-900);">
                {m.tag}
              </div>
              <figcaption class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
                <h3 class="font-display text-2xl lg:text-4xl mb-1" style="color: var(--v2-cream-50);">
                  {m.title}
                </h3>
                <p class="text-sm lg:text-base" style="color: rgba(253,251,244,0.8);">
                  {m.caption}
                </p>
              </figcaption>
            </figure>
          );
        })
      }
    </div>
    <p class="mt-6 text-xs italic text-center" style="color: rgba(7,29,48,0.45);">
      {COPY.consent}
    </p>
  </div>
</section>