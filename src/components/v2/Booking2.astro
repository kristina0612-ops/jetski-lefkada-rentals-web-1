---
// Bokun booking widget section for v2 Azure Day
// TODO: Replace BOKUN_EMBED_CODE with the actual script/iframe from Bokun dashboard
// How to get it: Bokun → Products → Your product → Booking widget → Copy embed code
const BOKUN_EMBED_CODE = ""; // ← paste Bokun embed code here
---

<section id="book" class="relative py-24 lg:py-32" style="background: var(--v2-ink-950);">
  <div class="mx-auto max-w-[1600px] px-6 lg:px-12">

    <div class="grid grid-cols-12 gap-6 mb-12">
      <div class="col-span-12 lg:col-span-8">
        <div class="v2-eyebrow mb-6" style="color: var(--v2-sun-400);"><span>Book your ride</span></div>
        <h2 class="v2-display text-5xl lg:text-[clamp(3.5rem,6vw,6.5rem)]" style="color: var(--v2-cream-50);">
          Pick a date.<br><em style="color: var(--v2-sun-400);">We handle the rest.</em>
        </h2>
      </div>
    </div>

    <!-- Water Fun add-on -->
    <div class="mb-10 rounded-2xl border overflow-hidden grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 items-center p-8 lg:p-10" style="border-color: rgba(255,194,51,0.35); background: linear-gradient(135deg, rgba(255,194,51,0.08), rgba(0,179,167,0.06));">
      <div>
        <div class="v2-eyebrow mb-3" style="color: var(--v2-sun-400);"><span>Add-on · Water Fun</span></div>
        <h3 class="font-display text-3xl lg:text-4xl mb-3" style="color: var(--v2-cream-50);">
          Three rings. One jetski. <em style="color: var(--v2-sun-400);">Pure adrenaline.</em>
        </h3>
        <p class="text-base lg:text-lg max-w-2xl" style="color: rgba(253,251,244,0.8);">
          Get pulled through the Ionian on a three-ring tube behind one of our
          Sea-Doos. No driving required &mdash; just hold on and laugh.
          Perfect for groups, families, and anyone who prefers the ride to the wheel.
        </p>
      </div>
      <div class="flex flex-col items-start md:items-end gap-3">
        <div class="font-display text-5xl" style="color: var(--v2-sun-400);">€30<span class="text-xl opacity-75">/person</span></div>
        <a
          href="https://wa.me/306955612777?text=Hi%20David%2C%20I'd%20like%20to%20book%20Water%20Fun%20(30%E2%82%AC%20per%20person)."
          target="_blank"
          rel="noopener"
          class="v2-btn-ghost"
          style="color: var(--v2-cream-50); border-color: var(--v2-cream-50);"
          data-cro="v2-booking-waterfun"
        >
          Book Water Fun
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    {BOKUN_EMBED_CODE ? (
      <!-- Bokun widget renders here once embed code is pasted above -->
      <div class="bokun-widget rounded-2xl overflow-hidden" set:html={BOKUN_EMBED_CODE} />
    ) : (
      <!-- Fallback: shown until Bokun is connected -->
      <div class="rounded-2xl border p-10 lg:p-16 text-center" style="border-color: rgba(253,251,244,0.15); background: rgba(253,251,244,0.04);">
        <div class="font-display italic text-6xl mb-4" style="color: var(--v2-sun-400);">📅</div>
        <h3 class="font-display text-3xl mb-4" style="color: var(--v2-cream-50);">Online booking coming soon.</h3>
        <p class="text-lg mb-8 max-w-md mx-auto" style="color: rgba(253,251,244,0.65);">
          For now, the fastest way to book is a quick WhatsApp to David.
          Usually confirmed within the hour.
        </p>
        <a
          href="https://wa.me/306955612777?text=Hi%20David%2C%20I'd%20like%20to%20book%20a%20jetski."
          target="_blank"
          rel="noopener"
          class="v2-btn inline-flex"
          style="background: var(--v2-sun-400); color: var(--v2-ink-950);"
          data-cro="v2-booking-whatsapp"
        >
          WhatsApp David
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.304-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
          </svg>
        </a>
      </div>
    )}

  </div>
</section>
