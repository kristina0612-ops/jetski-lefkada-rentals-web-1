---
// Booking section – Nero Lefkada v2 Azure Day
// Three pieces on this section:
//   1. Water-Fun add-on card (Jobe Ridge tube)
//   2. Calculator (instant price check, no obligation)
//   3. BookingForm (full booking: contact, licence gate, 30% deposit, 3 consents)
// Bokun embed is kept as optional drop-in for later.
const BOKUN_EMBED_CODE = ""; // ← optional: paste Bokun embed to replace the form
import BookingForm from "../BookingForm.tsx";
import Calculator from "../Calculator.tsx";
---

<section id="book" class="relative py-24 lg:py-32" style="background: var(--v2-ink-950);">
  <div class="mx-auto max-w-[1600px] px-6 lg:px-12">

    <div class="grid grid-cols-12 gap-6 mb-12">
      <div class="col-span-12 lg:col-span-8">
        <div class="v2-eyebrow mb-6" style="color: var(--v2-sun-400);"><span>Book your ride</span></div>
        <h2 class="v2-display text-5xl lg:text-[clamp(3.5rem,6vw,6.5rem)]" style="color: var(--v2-cream-50);">
          Pick a date.<br><em style="color: var(--v2-sun-400);">We handle the rest.</em>
        </h2>
      </div>
    </div>

    <!-- Water Fun add-on: 3-seat towable tube pulled behind a Sea-Doo.
         Photo: waterfun-tube-action.jpg (© kallerna, CC BY-SA 3.0, via
         Wikimedia Commons — „Towable water tube in Makadi Bay"). Gewählt
         2026-04-20 als freie Tube-Action-Darstellung bis Kristina/David
         ein eigenes Jetski+Tube-Foto schießen. NOTE: Das Wikimedia-Bild
         zeigt ein Motorboot statt Jetski — das Text-Copy bleibt korrekt
         (Ihr verwendet Jetski), aber bei eigenem Foto sofort tauschen. -->
    <div id="water-fun" class="mb-10 rounded-2xl border overflow-hidden grid grid-cols-1 md:grid-cols-2 scroll-mt-24" style="border-color: rgba(255,194,51,0.35); background: linear-gradient(135deg, rgba(255,194,51,0.08), rgba(0,179,167,0.06));">
      <div class="relative aspect-[4/3] md:aspect-auto md:min-h-[380px] overflow-hidden">
        <img
          src="/images/gallery/waterfun-tube-action.jpg"
          alt="Jobe Ridge three-seat towable tube in action on the turquoise Ionian Sea near Lygia Port"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, transparent 30%, rgba(7,29,48,0.35) 100%);"></div>
        <div class="absolute top-4 left-4 font-mono text-[10px] uppercase tracking-[0.18em] px-3 py-1.5 rounded-full" style="background: rgba(7,29,48,0.75); color: var(--v2-sun-400); backdrop-filter: blur(6px);">
          Jobe Ridge · 3 seats
        </div>
      </div>

      <!-- Copy + price + CTA -->
      <div class="p-8 lg:p-10 flex flex-col justify-center gap-4">
        <div class="v2-eyebrow" style="color: var(--v2-sun-400);"><span>Add-on · Water Fun</span></div>
        <h3 class="font-display text-3xl lg:text-4xl" style="color: var(--v2-cream-50);">
          Three seats. One tube. <em style="color: var(--v2-sun-400);">Pure adrenaline.</em>
        </h3>
        <p class="text-base lg:text-lg" style="color: rgba(253,251,244,0.8);">
          Get pulled through the Ionian on a three-seat Jobe Ridge towable
          behind one of our Neros. No driving required &mdash; just hold on and
          laugh. Perfect for groups, families, and anyone who prefers the
          ride to the wheel.
        </p>
        <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
          <div class="font-display text-5xl" style="color: var(--v2-sun-400);">€30<span class="text-xl opacity-75">/person</span></div>
          <a
            href="https://wa.me/306955612777?text=Hi%20David%2C%20I'd%20like%20to%20book%20Water%20Fun%20(30%E2%82%AC%20per%20person)."
            target="_blank"
            rel="noopener"
            class="v2-btn-ghost"
            style="color: var(--v2-cream-50); border-color: var(--v2-cream-50);"
            data-cro="v2-booking-waterfun"
          >
            Book Water Fun
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Price calculator: quick check without commitment -->
    <div id="calculator" class="mb-10 scroll-mt-24">
      <div class="mb-4">
        <div class="v2-eyebrow" style="color: var(--v2-sun-400);"><span>Step 1 · Quick price check</span></div>
        <h3 class="font-display text-2xl lg:text-3xl mt-2" style="color: var(--v2-cream-50);">
          Try the calculator &mdash; <em style="color: var(--v2-sun-400);">no booking yet.</em>
        </h3>
      </div>
      <Calculator client:visible />
    </div>

    {BOKUN_EMBED_CODE ? (
      <!-- Bokun widget takes over once embed code is pasted above -->
      <div class="bokun-widget rounded-2xl overflow-hidden" set:html={BOKUN_EMBED_CODE} />
    ) : (
      <!-- Full booking form: contact, billing, licence gate, 30% deposit, 3 consents -->
      <div id="booking-form" class="scroll-mt-24">
        <div class="mb-4">
          <div class="v2-eyebrow" style="color: var(--v2-sun-400);"><span>Step 2 · Complete booking</span></div>
          <h3 class="font-display text-2xl lg:text-3xl mt-2" style="color: var(--v2-cream-50);">
            Ready to book? <em style="color: var(--v2-sun-400);">30% deposit online.</em>
          </h3>
        </div>
        <BookingForm client:visible />
      </div>
    )}

  </div>
</section>
