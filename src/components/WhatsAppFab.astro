---
// WhatsApp floating action button + sticky booking CTA on mobile
const whatsappUrl = "https://wa.me/306955612777?text=Hi%20David%2C%20I%20have%20a%20question%20about%20renting%20a%20jetski";
---

<!-- Desktop + mobile: floating WhatsApp -->
<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener"
  aria-label="Chat with David on WhatsApp"
  data-cro="whatsapp-fab"
  class="fixed bottom-6 right-6 z-50 group"
>
  <div class="relative">
    <!-- Pulse ring -->
    <span class="absolute inset-0 rounded-full bg-coral-500 opacity-40" style="animation: pulse-dot 2.5s ease-in-out infinite;"></span>

    <div class="relative w-16 h-16 bg-coral-500 hover:bg-coral-400 transition-colors duration-500 rounded-full flex items-center justify-center shadow-[0_12px_40px_-10px_rgba(255,90,54,0.7)]">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="#050910" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.304-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
      </svg>
    </div>

    <!-- Tooltip -->
    <div class="absolute right-full mr-4 top-1/2 -translate-y-1/2 bg-ink-900 border border-brass-500/40 px-4 py-2 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none hidden md:block">
      <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-paper-100">
        Chat with David
      </span>
      <div class="absolute left-full top-1/2 -translate-y-1/2 w-0 h-0 border-l-[6px] border-l-ink-900 border-y-[6px] border-y-transparent"></div>
    </div>
  </div>
</a>

<!-- Mobile: sticky bottom booking CTA (appears after scroll) -->
<div
  id="sticky-book-bar"
  class="fixed bottom-0 left-0 right-0 z-40 bg-ink-950/95 backdrop-blur-sm border-t border-brass-500/30 p-4 translate-y-full transition-transform duration-700 lg:hidden"
>
  <div class="flex items-center gap-3 pr-20">
    <div class="flex-1 min-w-0">
      <div class="font-display text-paper-100 text-sm leading-none">Ride today</div>
      <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-coral-500 mt-1">
        From €70/hr · 3 available
      </div>
    </div>
    <a href="#fleet" class="btn-coral !py-3 !px-5 !text-xs shrink-0" data-cro="sticky-cta">
      Book
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>

<script>
  // Show sticky bar after 40% scroll on mobile
  const stickyBar = document.getElementById("sticky-book-bar");
  if (stickyBar) {
    const onScroll = () => {
      const threshold = window.innerHeight * 1.2;
      if (window.scrollY > threshold) {
        stickyBar.classList.remove("translate-y-full");
      } else {
        stickyBar.classList.add("translate-y-full");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
